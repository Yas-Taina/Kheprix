meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/autenticacao/login
  body: json
  auth: none
}

body:json {
  {
    "autenticacao": {
      "email": "mateus@exemplo.com",
      "senha": "senha123"
    }
  }
}

script:post-response {
  if (res.body.token) {
    bru.setEnvVar("token", res.body.token);
  }
}
